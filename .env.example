# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Email (Gmail) ──────────────────────────────────────────────────────────────
# The Gmail account you're sending FROM (enable App Password in Google Account settings)
BRIEFING_FROM_EMAIL=yourgmail@gmail.com

# Your App Password (NOT your Gmail password) — Google Account > Security > App Passwords
BRIEFING_EMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Where to deliver the briefing (can be same as FROM or different)
BRIEFING_TO_EMAIL=youremail@gmail.com

# ── Telegram (optional but recommended for phone notifications) ────────────────
# Step 1: Message @BotFather on Telegram → /newbot → copy the token below
TELEGRAM_BOT_TOKEN=

# Step 2: Message @userinfobot on Telegram → copy your Chat ID below
TELEGRAM_CHAT_ID=
